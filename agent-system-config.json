  "shared_resources": [
    {
      "id": "postgres-primary",
      "name": "PostgreSQL Database",
      "type": "database",
      "compute": {
        "vcpu": 4,
        "memory_gb": 8
      },
      "storage": {
        "size_gb": 100,
        "type": "SSD",
        "redundancy": "RAID1"
      },
      "access": ["backend-expert-001"],
      "port": 5432,
      "backup_strategy": {
        "full": "daily at 02:00",
        "incremental": "every 6 hours",
        "retention_days": 30
      }
    },
    {
      "id": "redis-cache",
      "name": "Redis Cache",
      "type": "cache",
      "compute": {
        "vcpu": 2,
        "memory_gb": 4
      },
      "storage": {
        "size_gb": 10,
        "type": "SSD"
      },
      "access": ["backend-expert-001"],
      "port": 6379,
      "persistence": {
        "enabled": true,
        "method": "AOF"
      }
    },
    {
      "id": "s3-storage",
      "name": "S3-Compatible Object Storage",
      "type": "storage",
      "storage": {
        "size_gb": 50,
        "breakdown": {
          "product_images": 10,
          "user_uploads": 5,
          "backups": 20,
          "logs": 5
        }
      },
      "access": ["backend-expert-001", "frontend-expert-001"],
      "protocol": "HTTP/HTTPS"
    }
  ],
  "quality_gates": [
    {
      "id": "QG-001-Commit",
      "name": "Code Commit Quality Gate",
      "trigger": "on git commit",
      "checks": [
        {
          "name": "Linting",
          "tool": "ESLint/Pylint",
          "required": true,
          "timeout_seconds": 30
        },
        {
          "name": "Code Formatting",
          "tool": "Prettier",
          "required": true,
          "timeout_seconds": 30
        },
        {
          "name": "Type Checking",
          "tool": "TypeScript/mypy",
          "required": true,
          "timeout_seconds": 60
        },
        {
          "name": "Unit Tests",
          "tool": "Jest/pytest",
          "required": true,
          "timeout_seconds": 300
        },
        {
          "name": "Secret Detection",
          "tool": "detect-secrets",
          "required": true,
          "timeout_seconds": 30
        }
      ],
      "pass_criteria": "All checks must pass",
      "fail_action": "Block commit"
    },
    {
      "id": "QG-002-PR",
      "name": "Pull Request Quality Gate",
      "trigger": "on pull request",
      "checks": [
        {
          "name": "All QG-001 Checks",
          "required": true
        },
        {
          "name": "Integration Tests",
          "tool": "Jest/pytest",
          "required": true,
          "timeout_seconds": 600
        },
        {
          "name": "E2E Tests",
          "tool": "Playwright",
          "required": false,
          "timeout_seconds": 900
        },
        {
          "name": "Code Coverage",
          "tool": "Coverage.py/Jest",
          "required": true,
          "threshold": 85,
          "timeout_seconds": 120
        },
        {
          "name": "Performance Tests",
          "tool": "Lighthouse",
          "required": true,
          "threshold": 90,
          "timeout_seconds": 300
        },
        {
          "name": "Security Scan",
          "tool": "Snyk/OWASP",
          "required": true,
          "timeout_seconds": 300
        },
        {
          "name": "Accessibility Tests",
          "tool": "axe-core",
          "required": true,
          "timeout_seconds": 120
        },
        {
          "name": "Code Review",
          "required": true,
          "min_approvals": 1
        }
      ],
      "pass_criteria": "All checks must pass + code review approved",
      "fail_action": "Block merge"
    },
    {
      "id": "QG-003-PreDeploy",
      "name": "Pre-Deployment Quality Gate",
      "trigger": "before merge to main",
      "checks": [
        {
          "name": "All QG-002 Checks",
          "required": true
        },
        {
          "name": "Build Artifact Creation",
          "required": true,
          "timeout_seconds": 600
        },
        {
          "name": "Docker Image Build",
          "required": true,
          "timeout_seconds": 600
        },
        {
          "name": "Database Migrations",
          "required": true,
          "timeout_seconds": 300
        },
        {
          "name": "Environment Configuration",
          "required": true,
          "timeout_seconds": 60
        },
        {
          "name": "Deployment Script Test",
          "required": true,
          "timeout_seconds": 300
        }
      ],
      "pass_criteria": "All checks must pass",
      "fail_action": "Prevent deployment"
    },
    {
      "id": "QG-004-PostDeploy",
      "name": "Post-Deployment Monitoring Gate",
      "trigger": "after deployment",
      "duration_minutes": 60,
      "checks": [
        {
          "name": "Application Health Check",
          "required": true,
          "interval_seconds": 30
        },
        {
          "name": "Error Rate Monitor",
          "required": true,
          "threshold": 0.5,
          "unit": "percent"
        },
        {
          "name": "Performance Degradation",
          "required": true,
          "threshold": 5,
          "unit": "percent"
        },
        {
          "name": "Database Connection Stability",
          "required": true
        },
        {
          "name": "Security Vulnerability Scan",
          "required": true
        },
        {
          "name": "API Response Time (p95)",
          "required": true,
          "threshold": 200,
          "unit": "milliseconds"
        }
      ],
      "pass_criteria": "All checks must pass for 60 minutes",
      "fail_action": "Auto-rollback to previous version"
    }
  ],
  "communication_events": [
    {
      "event_type": "code.commit",
      "subscribers": ["monitor-001", "git-expert-001"],
      "priority": "medium"
    },
    {
      "event_type": "code.push",
      "subscribers": ["git-expert-001", "monitor-001"],
      "priority": "medium"
    },
    {
      "event_type": "test.started",
      "subscribers": ["monitor-001"],
      "priority": "low"
    },
    {
      "event_type": "test.completed",
      "subscribers": ["monitor-001", "git-expert-001"],
      "priority": "medium"
    },
    {
      "event_type": "test.failed",
      "subscribers": ["monitor-001", "git-expert-001"],
      "priority": "high"
    },
    {
      "event_type": "deployment.started",
      "subscribers": ["monitor-001"],
      "priority": "medium"
    },
    {
      "event_type": "deployment.completed",
      "subscribers": ["monitor-001", "frontend-expert-001", "backend-expert-001"],
      "priority": "medium"
    },
    {
      "event_type": "deployment.failed",
      "subscribers": ["monitor-001", "git-expert-001"],
      "priority": "critical"
    },
    {
      "event_type": "error.detected",
      "subscribers": ["monitor-001"],
      "priority": "high"
    },
    {
      "event_type": "security.vulnerability",
      "subscribers": ["monitor-001"],
      "priority": "critical"
    },
    {
      "event_type": "quality.gate.passed",
      "subscribers": ["git-expert-001"],
      "priority": "medium"
    },
    {
      "event_type": "quality.gate.failed",
      "subscribers": ["monitor-001"],
      "priority": "high"
    }
  ],
  "status_report_interval_minutes": 15,
  "health_check_interval_seconds": 30,
  "alert_rules": {
    "agent_downtime": {
      "threshold_minutes": 5,
      "severity": "critical",
      "notify": ["slack", "pagerduty"]
    },
    "high_error_rate": {
      "threshold_percent": 1,
      "severity": "high",
      "notify": ["slack", "email"]
    },
    "low_test_coverage": {
      "threshold_percent": 80,
      "severity": "medium",
      "notify": ["slack"]
    },
    "security_vulnerability": {
      "severity": "critical",
      "notify": ["slack", "pagerduty", "email"]
    }
  },
  "deployment": {
    "environments": [
      {
        "name": "development",
        "agents": ["frontend-expert-001", "backend-expert-001"],
        "auto_deploy": true,
        "quality_gates": ["QG-001-Commit"]
      },
      {
        "name": "staging",
        "agents": ["frontend-expert-001", "backend-expert-001"],
        "auto_deploy": false,
        "quality_gates": ["QG-001-Commit", "QG-002-PR", "QG-003-PreDeploy"]
      },
      {
        "name": "production",
        "agents": ["frontend-expert-001", "backend-expert-001"],
        "auto_deploy": false,
        "quality_gates": ["QG-001-Commit", "QG-002-PR", "QG-003-PreDeploy", "QG-004-PostDeploy"],
        "requires_approval": true
      }
    ]
  }
}
